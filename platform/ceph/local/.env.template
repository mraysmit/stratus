# Disposable real Ceph/RGW deployed by the local Docker Compose environment.
CEPH_RGW_ENDPOINT=https://object-store.stratus.local:8443
CEPH_RGW_PORT=8443
# Host interface for the published RGW port. Keep loopback unless remote access is deliberate.
CEPH_RGW_BIND_ADDRESS=127.0.0.1

# Disposable local-only RGW identity. The startup scripts replace the key values
# below with generated per-machine secrets when creating .env from this template.
# Never reuse these values outside this lab.
CEPH_DEMO_UID=stratus-verifier
CEPH_RGW_ACCESS_KEY=generated-at-first-startup
CEPH_RGW_SECRET_KEY=generated-at-first-startup

# Separate disposable owner used to prove that the verifier cannot cross an RGW identity boundary.
CEPH_DENIED_UID=stratus-denied-owner
CEPH_DENIED_ACCESS_KEY=generated-at-first-startup
CEPH_DENIED_SECRET_KEY=generated-at-first-startup
CEPH_RGW_DENIED_BUCKET=stratus-denied

# Ceph Dashboard (management console), served through the TLS proxy.
CEPH_DASHBOARD_PORT=8444
# Host interface for the published dashboard port. Keep loopback unless remote access is deliberate.
CEPH_DASHBOARD_BIND_ADDRESS=127.0.0.1
# Disposable local-only dashboard sign-in. The startup scripts replace the
# password below with a generated per-machine secret.
CEPH_DASHBOARD_USER=stratus-dashboard
CEPH_DASHBOARD_PASSWORD=generated-at-first-startup

CEPH_RGW_PROBE_BUCKET=stratus-landing
S3_PATH_STYLE_ACCESS=true
S3_CONNECTION_TIMEOUT_MS=5000
S3_SOCKET_TIMEOUT_MS=10000
S3_API_CALL_ATTEMPT_TIMEOUT_MS=15000
S3_API_CALL_TIMEOUT_MS=30000
# CEPH_RGW_ALLOW_HTTP and USE_SYSTEM_CA_CERTS are fixed in compose.yaml and not configurable here.
STRATUS_LOG_LEVEL=INFO
STRATUS_LOG_FILE=/evidence/storage-verifier.%g.log
STRATUS_LOG_MAX_BYTES=10485760
STRATUS_LOG_FILE_COUNT=5

# docker, podman, or auto.
COMPOSE_IMPLEMENTATION=docker

# The local Ceph image is the official pinned Ceph 20.2.2 OCI index.
CEPH_IMAGE=quay.io/ceph/ceph:v20.2.2@sha256:6b4b5ae33acd3d736eb26d2a19238bce71a22f9cfb99cca887ba6312d0957644
RGW_PROXY_IMAGE=nginx:1.29.8-alpine

# Client and verifier images are prebuilt. Compose never builds them.
# The :dev tag is a local-build convenience; recorded verification runs must
# replace it with a digest-pinned reference from the build system.
S3CLIENT_IMAGE=rclone/rclone:1.74.4
VERIFIER_IMAGE=stratus/storage-verifier:dev
